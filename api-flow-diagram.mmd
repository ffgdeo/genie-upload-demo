sequenceDiagram
    autonumber
    participant U as User
    participant FE as React Frontend
    participant BE as FastAPI Backend
    participant SQL as SQL Statement API
    participant DR as Data Rooms API
    participant GC as Genie Conversation API

    rect rgb(220, 235, 255)
        Note over U,GC: Phase 1 — File Upload & Table Creation

        U->>FE: Upload CSV / Excel file
        FE->>BE: POST /upload (multipart form)
        activate BE
        BE->>BE: Parse file with pandas
        BE->>SQL: POST /api/2.0/sql/statements<br/>(CREATE TABLE DDL)
        activate SQL
        SQL-->>BE: statement_id + status OK
        deactivate SQL
        BE->>SQL: POST /api/2.0/sql/statements<br/>(INSERT INTO — batched rows)
        activate SQL
        SQL-->>BE: statement_id + status OK
        deactivate SQL
        BE-->>FE: { table_name, schema }
        deactivate BE
        FE-->>U: Show table preview + schema
    end

    rect rgb(220, 255, 230)
        Note over U,GC: Phase 2 — Genie Space Creation

        FE->>BE: POST /create-genie-space<br/>{ table_name }
        activate BE
        BE->>DR: POST /api/2.0/data-rooms/<br/>{ display_name, warehouse_id,<br/>  table_identifiers, run_as_type }
        activate DR
        DR-->>BE: { space_id }
        deactivate DR
        BE-->>FE: { space_id }
        deactivate BE
        FE-->>U: Transition to Chat Interface
    end

    rect rgb(255, 245, 215)
        Note over U,GC: Phase 3 — Natural Language Query (repeatable)

        U->>FE: Type a question
        FE->>BE: POST /query<br/>{ space_id, question }
        activate BE

        alt First message in conversation
            BE->>GC: genie.start_conversation_and_wait()<br/>→ POST /api/2.0/genie/spaces/{id}/start-conversation
            activate GC
            GC->>GC: Generate SQL & execute
            GC-->>BE: { conversation_id, message_id, attachments }
            deactivate GC
        else Follow-up message
            BE->>GC: genie.create_message_and_wait()<br/>→ POST /api/2.0/genie/spaces/{id}/conversations/{conv_id}/messages<br/>{ conversation_id, content }
            activate GC
            GC->>GC: Generate SQL & execute (with context)
            GC-->>BE: { message_id, attachments }
            deactivate GC
        end

        BE->>GC: genie.get_message_query_result_by_attachment()<br/>→ GET attachment data rows
        activate GC
        GC-->>BE: { columns, rows }
        deactivate GC

        BE-->>FE: { sql_query, data_rows, text_response }
        deactivate BE
        FE->>FE: Render data table
        FE->>FE: Auto-generate chart from data
        FE-->>U: Display table + chart + text answer
    end
